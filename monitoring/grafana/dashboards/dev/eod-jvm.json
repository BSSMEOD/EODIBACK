            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "sum by (action) (rate(jvm_gc_pause_seconds_count{application=\"eod\",env=~\"$env\"}[5m])) * 60",
          "legendFormat": "{{action}}",
          "refId": "A"
        }
      ],
